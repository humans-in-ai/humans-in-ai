ANTHROPIC_API_KEY=sk-ant-...

# Database (Turso / libSQL). Leave unset locally to use a local file:./booth.db.
# In production set both to your Turso database credentials.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Local-only HTTP port (ignored on Vercel)
PORT=3000

# Tunables
TURNS_PER_SESSION=3
GUESS_TURNS=6
HAIKU_MODEL=claude-haiku-4-5
GUESS_OPERATOR_TIMEOUT_MS=8000
